{
  "name": "froggyhatessnow-wiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node -e \"const fs=require('node:fs'); for (const p of ['.astro','node_modules/.astro']) fs.rmSync(p,{recursive:true,force:true});\"",
    "build": "astro build",
    "preview": "astro preview",
    "scan": "tsx scripts/scan-game-files.ts",
    "fetch:steam": "tsx scripts/fetch-steam-public-data.ts",
    "refresh:data": "npm run fetch:steam && npm run scan && npm run validate && npm run generate",
    "build:verified": "npm run refresh:data && npm run build",
    "domain:check": "tsx scripts/porkbun-domain.ts check",
    "domain:status": "tsx scripts/porkbun-domain.ts status",
    "domain:register": "tsx scripts/porkbun-domain.ts register",
    "domain:dns": "tsx scripts/porkbun-domain.ts dns",
    "domain:finish": "tsx scripts/domain-finish.ts",
    "domain:finish:post-verification": "tsx scripts/domain-finish.ts --confirm-register-and-dns --commit-canonical-after-success",
    "domain:vercel-price": "tsx scripts/vercel-domain-buy.ts price",
    "domain:vercel-buy": "tsx scripts/vercel-domain-buy.ts buy",
    "domain:health": "tsx scripts/domain-health.ts",
    "domain:commit-canonical": "tsx scripts/domain-commit-canonical.ts",
    "deploy:status": "tsx scripts/vercel-status.ts",
    "deploy:publish": "tsx scripts/vercel-publish.ts",
    "generate": "tsx scripts/generate-pages.ts",
    "validate": "tsx scripts/validate-data.ts",
    "audit:completion": "tsx scripts/completion-audit.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.35.0",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
